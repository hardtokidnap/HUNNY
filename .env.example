# Discord bot token. Get one from https://discord.com/developers/applications
# Never commit your real token.
DISCORD_TOKEN=your-bot-token-here

# --- Storage (optional) ---
# By default the bot uses a local SQLite file (data/honeypot.db).

# Override the SQLite file location (e.g. a mounted disk or Docker volume):
#DATABASE_PATH=/data/honeypot.db

# Set DATABASE_URL to use PostgreSQL instead of SQLite. Recommended on hosts
# with an ephemeral filesystem (e.g. Heroku, where the add-on sets this for you).
#DATABASE_URL=postgres://user:password@host:5432/dbname

# TLS to Postgres is on by default for non-local hosts and off for localhost.
# Force it with: true / false.
#DATABASE_SSL=true
